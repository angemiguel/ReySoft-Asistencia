# Database
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# JWT
SECRET_KEY=generate-a-secure-random-secret-key

# App
APP_NAME=ReySoft-Asistencia
ENVIRONMENT=production
DEBUG=false

# CORS (comma-separated)
CORS_ORIGINS=https://your-frontend-domain.vercel.app

# Storage (local or supabase)
STORAGE_BACKEND=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=school-logos
UPLOAD_DIR=/tmp/uploads

# Initial super admin (first-run seeding)
INITIAL_SUPER_ADMIN_EMAIL=superadmin@reysoft-asistencia.com
INITIAL_SUPER_ADMIN_PASSWORD=SuperAdmin123!

# Supabase database (for direct connection)
SUPABASE_DATABASE_URL=postgresql+psycopg://postgres:password@aws-0-region.pooler.supabase.com:6543/postgres
